#!/usr/bin/env bash

set -euo pipefail

PROJECTS_ROOT="$HOME/dev"

have() { command -v "$1" >/dev/null 2>&1; }

pick_project() {
    fd . $PROJECTS_ROOT --exact-depth 1 -t d \
        | sort -u \
        | fzf --prompt="Project > "
}

session_name_from_path() {
    local p="$1"
    #Use repo folder name, plus a short hash to avoid collisions
    local base
    base="$(basename "$p")"
    printf "%s" "$base"
}

session_setup() {
    local session="$1"
    local dir="$2"

    # Window 1: nvim
    tmux rename-window -t $session:1 neovim
    tmux send-keys -t $session:1 'nvim .' C-m ' sf'
    tmux split-window -h -l 20% -c "$dir" -t $session:1
    tmux send-keys -t $session:1.1 'opencode' C-m
     
    # Window 2: DB 
    tmux new-window -t $session -n db -c $dir
    tmux send-keys -t $session:2 'pgdev' C-m

    tmux new-window -t $session -n scratch -c $dir
}

main() {
    have fd || { echo "fd is required"; exit 1; }
    have fzf || { echo "fzf is required"; exit 1; }
    have tmux || { echo "tmux is required"; exit 1; }

    local dir
    dir="$(pick_project || true)"
    [ -n "${dir:-}" ] || exit 0

    local session
    session="$(session_name_from_path "$dir")"

    # if session does not exist, create new one
    if ! tmux has-session -t $session 2>/dev/null; then
        tmux new-session -d -s $session -c $dir
        session_setup "$session" "$dir"
    fi


    tmux select-window -t $session:1.0
    tmux select-pane -t $session:1.0
    tmux resize-pane -Z

    if [ -n "${TMUX:-}" ]; then
        tmux switch-client -t $session
    else
        tmux attach -t $session
    fi
}


main "$@"


